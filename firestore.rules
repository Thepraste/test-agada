rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /volunteers/{volunteerId} {
      allow create: if isValidId(volunteerId)
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30;
      allow read, update, delete: if false;
    }

    match /donations/{donationId} {
      allow create: if isValidId(donationId)
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150
        && request.resource.data.amount is int
        && request.resource.data.amount > 0;
      allow read, update, delete: if false;
    }

    match /partnerships/{partnershipId} {
      allow create: if isValidId(partnershipId)
        && request.resource.data.orgName is string
        && request.resource.data.orgName.size() <= 200
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150;
      allow read, update, delete: if false;
    }

    match /program_applications/{applicationId} {
      allow create: if isValidId(applicationId)
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150;
      allow read, update, delete: if false;
    }

    match /contacts/{contactId} {
      allow create: if isValidId(contactId)
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if false;
    }

    match /newsletters/{emailHash} {
      allow create, update: if request.resource.data.email is string
        && request.resource.data.email.size() <= 150;
      allow read, delete: if false;
    }
  }
}
